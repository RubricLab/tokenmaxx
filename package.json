{
	"author": "Rubric Labs",
	"bin": {
		"tokenmaxx": "dist/launcher.cjs"
	},
	"dependencies": {
		"@opentui/core": "^0.4.3",
		"zod": "^4.0.0"
	},
	"description": "A local proxy that juggles rate limits across your Codex and Claude Code accounts — with live token-throughput analytics.",
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@rubriclab/config": "*",
		"@rubriclab/package": "*",
		"@types/bun": "^1.2.0",
		"typescript": "^5.8.0"
	},
	"engines": {
		"bun": ">=1.2.0"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"homepage": "https://tokenmaxx.sh",
	"keywords": [
		"analytics",
		"claude-code",
		"cli",
		"codex",
		"proxy",
		"rate-limits",
		"rubric",
		"tokens"
	],
	"license": "gonuts",
	"main": "dist/index.js",
	"name": "tokenmaxx",
	"preferGlobal": true,
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/RubricLab/tokenmaxx.git"
	},
	"scripts": {
		"assets": "bun run assets:screens && bun run assets:flagship",
		"assets:flagship": "bun run assets/flagship.ts",
		"assets:screens": "bun run assets/render.ts",
		"bleed": "bun x npm-check-updates -u",
		"build": "bun run clean && bun build ./src/index.ts --target bun --outdir dist --external '@opentui/*' && cp bin/launcher.cjs dist/launcher.cjs && chmod 755 dist/index.js dist/launcher.cjs",
		"check": "bun run typecheck && bun x biome check . && bun test",
		"clean": "rm -rf dist",
		"dev": "bun run src/index.ts",
		"format": "bun x biome check --write .",
		"prepare": "bun x @rubriclab/package prepare",
		"typecheck": "tsc --noEmit"
	},
	"simple-git-hooks": {
		"post-commit": "bun x @rubriclab/package post-commit"
	},
	"type": "module",
	"version": "0.0.23"
}
